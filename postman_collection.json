{
  "info": {
    "name": "Finance Dashboard Backend",
    "_postman_id": "12345-abcde",
    "description": "API collection for finance backend with RBAC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"ADMIN\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Records - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 1000,\n  \"type\": \"INCOME\",\n  \"category\": \"Salary\",\n  \"date\": \"2025-01-01T00:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/records",
          "host": ["{{base_url}}"],
          "path": ["records"]
        }
      }
    },
    {
      "name": "Records - Get All",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/records",
          "host": ["{{base_url}}"],
          "path": ["records"]
        }
      }
    },
    {
      "name": "Records - Update",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 2000\n}"
        },
        "url": {
          "raw": "{{base_url}}/records/:id",
          "host": ["{{base_url}}"],
          "path": ["records", ":id"]
        }
      }
    },
    {
      "name": "Records - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/records/:id",
          "host": ["{{base_url}}"],
          "path": ["records", ":id"]
        }
      }
    },
    {
      "name": "Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/summary",
          "host": ["{{base_url}}"],
          "path": ["summary"]
        }
      }
    }
  ]
}
